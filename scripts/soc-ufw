#!/usr/bin/env bash
set -euo pipefail

action="${1:-}"
ip="${2:-}"

if [[ "$action" == "status" ]]; then
  /usr/sbin/ufw status | /usr/bin/head -n 1
  exit 0
fi

if [[ "$action" != "block" && "$action" != "unblock" ]]; then
  echo "usage: soc-ufw status|block|unblock [public-ipv4]" >&2
  exit 2
fi
if [[ ! "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
  echo "invalid IPv4" >&2; exit 2
fi
IFS=. read -r a b c d <<< "$ip"
for octet in "$a" "$b" "$c" "$d"; do
  (( octet >= 0 && octet <= 255 )) || { echo "invalid IPv4" >&2; exit 2; }
done
# 자가 잠금 및 내부 서비스 차단을 helper 레벨에서도 거부한다.
if (( a == 10 || a == 127 || a == 0 || a >= 224 )) ||
   (( a == 192 && b == 168 )) ||
   (( a == 172 && b >= 16 && b <= 31 )) ||
   (( a == 169 && b == 254 )) ||
   (( a == 100 && b >= 64 && b <= 127 )); then
  echo "protected/non-public IPv4" >&2; exit 3
fi

if [[ "$action" == "block" ]]; then
  /usr/sbin/ufw insert 1 deny from "$ip" comment "SOC-DASHBOARD"
else
  /usr/sbin/ufw delete deny from "$ip"
fi
