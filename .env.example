# ── SOC 대시보드 환경설정 예시 ──
# 실제 값을 채워 .env 로 복사하세요:  cp .env.example .env
# ⚠ .env 는 절대 커밋하지 마세요(.gitignore 에 이미 제외됨).

# ── 서버 ──
HOST=127.0.0.1               # 외부/Tailscale 접속 시 0.0.0.0
PORT=5055
DEBUG=False
SECRET_KEY=change-me-to-a-random-string    # 세션 서명 키(랜덤 고정 권장)

# ── 대시보드 로그인 ──
AUTH_ENABLED=True
DASH_USERNAME=admin
DASH_PASSWORD=change-me                     # 평문(시작 시 해시로 변환) — 또는 아래 해시 사용
# DASH_PASSWORD_HASH=                        # pbkdf2 해시(권장)
SESSION_HOURS=12

# ── 데모 모드 ──
DEMO_MODE=True               # True 면 실제 센서 없이 가상 데이터로 전 기능 동작

# ── AI (Claude) ──
ANTHROPIC_API_KEY=           # 비우면 규칙 기반 데모 분석으로 fallback

# ── 패킷 캡처 / 탐지 임계값 ──
CAPTURE_INTERFACE=           # 비우면 자동 감지
DDOS_PACKET_THRESHOLD=1000
PORT_SCAN_THRESHOLD=20
ALERT_CONFIDENCE_THRESHOLD=0.5

# ── SIEM 접근 로그 수집 (파일 tail) ──
SIEM_ACCESS_LOGS=            # "이름=경로;이름=경로"

# ── Syslog 수신 (원격 침해시도) ──
SYSLOG_ENABLED=True
SYSLOG_BIND=127.0.0.1
SYSLOG_PORT=5514             # 514 는 sudo 필요 → 비특권 5514 권장

# ── 허니팟 (유인 서비스) ──
HONEYPOT_ENABLED=True
HONEYPOT_BIND=127.0.0.1      # 실포착은 0.0.0.0 또는 신뢰 네트워크(Tailscale) IP
HONEYPOT_PORTS=              # 비우면 기본셋 2222,2323,3306,6379,8081,9200
HONEYPOT_COOLDOWN=30

# ── SSH 인증 로그 ──
AUTH_LOG_PATH=/var/log/auth.log
SSH_BRUTE_THRESHOLD=5
SSH_BRUTE_WINDOW=120

# ── IP 평판 (AbuseIPDB) ──
ABUSEIPDB_API_KEY=           # 비우면 데모 점수 fallback

# ── EDR / 네트워크 관제 ──
EDR_RESPONSE_MODE=simulate   # simulate | kill
NET_MONITOR_TARGETS=         # "이름=host:port;..."

# ── 알림 보존 ──
ALERT_RETENTION_DAYS=90
ALERT_AUTO_ARCHIVE=False

# ── SOAR 자동 대응 ──
SOAR_BLOCK_MODE=simulate     # simulate | ufw | iptables
SOAR_AUTO_BLOCK=True
SOAR_BLOCK_TTL_HOURS=24
SOAR_BLOCK_ALLOWLIST=        # 절대 차단 금지 IP/대역 (사설·Tailscale 은 자동 보호)

# ── 취약점 패치 (Ansible) ──
PATCH_APPLY_ENABLED=False    # True 라야 실제 패치 적용(기본 dry-run)
ANSIBLE_TARGETS=             # "이름=user@host;..."

# ── 웹 퍼징 (본인 서버만) ──
FUZZ_TARGETS=
FUZZ_RATE=5
FUZZ_MAX_REQUESTS=300

# ── 푸시 알림 (ntfy) ──
NTFY_ENABLED=False
NTFY_TOPIC=
NTFY_MIN_SEVERITY=CRITICAL

# ── 일일 리포트 ──
REPORT_HOUR=8
